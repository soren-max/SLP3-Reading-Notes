{
  "name": "slp3-kg-llm-reading-notes",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "cd apps/api && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "seed": "cd apps/api && python -m app.seed",
    "lint": "npm --workspace apps/web run lint"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
